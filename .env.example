# ======================================================================
# Bringo API - variables de entorno (ejemplo)
# Copia a .env y completa. El .env real NUNCA se commitea.
# La configuracion se valida al arrancar (fail-fast): ver src/core/config
# ======================================================================

NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose expone 5432 en localhost)
DATABASE_URL=postgresql://bringo:bringo@localhost:5432/bringo?schema=public

# JWT - secretos DISTINTOS para access y refresh (>= 32 chars en prod)
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# CORS - whitelist explicita separada por comas (nunca * en produccion)
CORS_ORIGINS=http://localhost:5173,http://localhost:4200

# Swagger UI (deshabilitar/proteger en produccion)
SWAGGER_ENABLED=true

# Redis (reservado; el MVP no lo usa todavia)
REDIS_URL=redis://localhost:6379

# SMTP de desarrollo (mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025

# ---------------- Matching engine (ver docs/design/06-matching.md §8) --
# Umbral minimo de reputacion (0 = deshabilitado para cold-start)
MATCH_REPUTATION_MIN=0
# Score inicial neutro para Travelers sin calificaciones
MATCH_REPUTATION_COLD_START=3.5
# Pesos del scoring - DEBEN sumar 1 (validado al arrancar)
MATCH_W_TIME=0.35
MATCH_W_REPUTATION=0.30
MATCH_W_CAPACITY=0.15
MATCH_W_FAIRNESS=0.15
MATCH_W_LOAD=0.05
# Ventana de aceptacion de una oferta (minutos) y reintentos
MATCH_ACCEPTANCE_WINDOW_MINUTES=30
MATCH_MAX_REASSIGN_ATTEMPTS=5
MATCH_MAX_CANDIDATES=20
MATCH_MAX_PARALLEL_PER_TRAVELER=3

# PgAdmin (solo desarrollo)
PGADMIN_DEFAULT_EMAIL=admin@bringo.local
PGADMIN_DEFAULT_PASSWORD=
